ow_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Customer" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="75"/><column index="2" value="70"/><column index="3" value="78"/><column index="4" value="140"/><column index="5" value="70"/><column index="6" value="234"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="ExchangeRates" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="48"/><column index="2" value="93"/><column index="3" value="94"/><column index="4" value="109"/><column index="5" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="KYCAuditLog" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="42"/><column index="2" value="99"/><column index="3" value="156"/><column index="4" value="163"/><column index="5" value="54"/><column index="6" value="99"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Transactions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="87"/><column index="2" value="99"/><column index="3" value="99"/><column index="4" value="131"/><column index="5" value="105"/><column index="6" value="156"/><column index="7" value="102"/><column index="8" value="76"/><column index="9" value="71"/><column index="10" value="76"/><column index="11" value="109"/><column index="12" value="101"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">--Customer Onboarding and Initial Exchange TRANSACTION
--1. Create new customer with KYC check
INSERT INTO Customer(
    CustomerID, FirstName, LastName, PhoneNumber, Address, KYCStatus)
    VALUES(73, &quot;Beefy&quot;, &quot;Jogger&quot;, &quot;+16147477376&quot;, &quot;123 Albion St, Boston&quot;, &quot;Pending&quot;);

-- Log KYC verification
INSERT INTO KYCAuditLog(
    LogID, FK_CustomerID, CheckDate, CheckType, Result, FK_EmployeeID)
    VALUES(64, 73, CURRENT_TIMESTAMP, &quot;DocumentVerification&quot;, &quot;Pass&quot;, 5);

-- Update customer KYC Status
UPDATE Customer
SET KYCStatus = &quot;Verified&quot;
WHERE CustomerID = 73;

-- Verify customer KYC status before processing large transaction
SELECT t.TransactionID, c.CustomerID, c.FirstName, c.LastName, c.KYCStatus, t.AmountReceived,
	CASE
		WHEN t.AmountReceived &gt; 500 AND c.KYCStatus != &quot;Verified&quot;
		THEN &quot;Hold&quot;
		ELSE &quot;Proceed&quot;
	END as TransactionAction
FROM Transactions t
JOIN Customer c ON t.FK_CustomerID=c.CustomerID
WHERE t.TransactionID= 63;

-- Process USD to ZAR exchange transaction
INSERT INTO Transactions( TransactionID, FK_CustomerID, FK_EmployeeID, FK_CurrencyReceived,
    FK_CurrencyPaid, DateTime, AmountReceived, AmountPaid, FK_RateID, AppliedRate,
    TransactionStatus, PaymentMode)
    VALUES(63, 73, 5, &quot;USD&quot;, &quot;ZAR&quot;, CURRENT_TIMESTAMP, 1000, 16000.00, 20, 16.00, &quot;Completed&quot;, &quot;CASH&quot;);

--Update cash inventory after disbursement
